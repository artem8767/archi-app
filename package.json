{
  "name": "archi-app",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-open.cjs",
    "dev:server": "next dev -p 3000 -H 0.0.0.0",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && node scripts/dev-open.cjs",
    "build": "next build",
    "build:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "check:play": "vitest run src/lib/play-store-readiness.test.ts",
    "play:readiness": "node scripts/run-play-readiness.cjs",
    "prepare:publish": "npm run release:check && node scripts/publish-reminders.cjs",
    "release:check": "npm run lint && npm run build && npm run test:run && npm run play:readiness",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:check-env": "node scripts/check-database-url.cjs .env",
    "db:push:vercel-prod": "node scripts/prisma-push-vercel-production.cjs",
    "vercel:env:add-resend": "node scripts/add-resend-to-vercel.cjs",
    "vercel:env:apply-brevo": "node scripts/apply-brevo-vercel-env.cjs",
    "email:check-local": "node scripts/check-email-env-present.cjs",
    "db:studio": "prisma studio",
    "deploy:vercel": "npx vercel deploy --prod --yes",
    "vercel:env:sync": "node scripts/sync-vercel-env-from-dotenv.cjs"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "leaflet": "^1.9.4",
    "next": "15.5.14",
    "next-intl": "^3.26.5",
    "nodemailer": "^8.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "glob": "13.0.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.19.17",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.14",
    "postcss": "^8.5.8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
