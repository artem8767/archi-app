# Повний URL сайту Next.js (ARCHI), без слеша в кінці.
# Для збірки AAB у хмарі EAS задайте ці змінні в eas.json → env або в Secrets на expo.dev.
EXPO_PUBLIC_SITE_URL=https://your-domain.com

# Стартова сторінка після відкриття додатку (шлях з next-intl, напр. /uk або /en).
EXPO_PUBLIC_SITE_PATH=/uk
