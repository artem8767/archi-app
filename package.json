{
  "name": "archi-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && next dev",
    "build": "next build",
    "build:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true})}catch(e){}\" && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
