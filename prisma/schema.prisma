generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  /// Опційно; реєстрація лише через email — нові акаунти зазвичай без номера.
  phone               String?  @unique
  passwordHash        String
  name                String?
  emailVerified       Boolean  @default(false)
  phoneVerified       Boolean  @default(false)
  locale              String   @default("en")
  autoTranslate       Boolean  @default(false)
  notificationLevel   Int      @default(100)
  lat                 Float?
  lng                 Float?
  addressLabel        String?
  wallpaperId         String   @default("original")
  uiTheme             String   @default("classic")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  verificationCodes VerificationCode[]
  newsPosts         NewsPost[]
  listings          Listing[]
  jobs              Job[]
  comments          Comment[]
  messages          ChatMessage[]
  newsVideoReports  NewsVideoReport[]
  blocksOut         UserBlock[]       @relation("UserBlocksOut")
  blocksIn          UserBlock[]       @relation("UserBlocksIn")
}

model VerificationCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, kind])
}

model NewsPost {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  title            String
  body             String
  imagesJson       String             @default("[]")
  videoUrl         String?
  createdAt        DateTime           @default(now())
  newsVideoReports NewsVideoReport[]
}

model NewsVideoReport {
  id         String   @id @default(cuid())
  reporterId String
  reporter   User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  newsPostId String
  newsPost   NewsPost @relation(fields: [newsPostId], references: [id], onDelete: Cascade)
  reason     String   @default("")
  createdAt  DateTime @default(now())

  @@unique([reporterId, newsPostId])
  @@index([newsPostId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("UserBlocksOut", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("UserBlocksIn", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model Listing {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    String
  // Маркетплейс-розділ (slug): auto_moto, real_estate, …
  section     String   @default("general")
  title       String
  description String
  price       String
  phone       String
  photosJson  String   @default("[]")
  createdAt   DateTime @default(now())
}

model Job {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city      String
  vacancy   String
  pay       String
  phone     String
  photo     String?
  createdAt DateTime @default(now())
}

model Comment {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  body       String
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
}

model ChatRoom {
  id       String        @id @default(cuid())
  name     String
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  roomId    String
  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // text | image | video | link | audio
  kind      String   @default("text")
  // Текст, підпис або URL (для link).
  text      String   @default("")
  // data: URL для фото / відео / аудіо.
  mediaData String   @default("")
  createdAt DateTime @default(now())
}
