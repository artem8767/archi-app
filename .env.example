DATABASE_URL="file:./dev.db"

# Опційно: OpenAI Moderation API для додаткової перевірки тексту (локальні правила працюють і без ключа).
# OPENAI_API_KEY=""
JWT_SECRET="change-this-to-a-long-random-string-in-production"

# --- E-mail (один з варіантів) ---
# Варіант A: Resend — https://resend.com/api-keys
# Після реєстрації створіть API key, у розділі Domains додайте свій домен або для тесту
# використовуйте відправника на @resend.dev (напр. onboarding@resend.dev).
# Якщо задано RESEND_API_KEY, листи йдуть через Resend (SMTP у .env ігнорується).
# На Vercel достатньо лише RESEND_API_KEY — без EMAIL_FROM використовується onboarding@resend.dev.
RESEND_API_KEY=""
EMAIL_FROM="АРЧІ <onboarding@resend.dev>"

# Варіант B: SMTP (Gmail App Password, Mailgun, тощо) — залиште RESEND_API_KEY порожнім
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="АРЧІ <noreply@yourdomain.com>"

# --- Підтвердження після реєстрації — лише EMAIL (код у листі) ---
# Потрібні RESEND_API_KEY + EMAIL_FROM або SMTP + EMAIL_FROM (див. вище).
# У development без пошти код показується у відповіді API реєстрації (якщо не production).
# SHOW_VERIFICATION_CODES="true" у production — коди в JSON (небезпечно, лише тест).
#
# Vercel / інший хост: у змінних середовища продакшену ОБОВ’ЯЗКОВО додайте ті самі ключі
# (RESEND_API_KEY + EMAIL_FROM тощо). Без них API /api/auth/register відповість 503 —
# на старих збірках могло бути повідомлення про SMS; у поточному коді — про лист.

# Мобільний застосунок (Expo) використовує заголовок Authorization: Bearer.
# CORS для /api увімкнено в middleware (дозволено * для зручності з Bearer).

# Підпис розробника у підвалі та на сторінці «Про застосунок» (також у HTML meta authors).
# Без NEXT_PUBLIC_SITE_DEVELOPER блок розробника не показується. Справжні дані — у .env (не в git).
# NEXT_PUBLIC_SITE_DEVELOPER="Your Name"
# NEXT_PUBLIC_SITE_DEVELOPER_URL="https://example.com"
# NEXT_PUBLIC_SITE_DEVELOPER_EMAIL="you@example.com"
# NEXT_PUBLIC_SITE_DEVELOPER_PHONE="+420000000000"

# --- Публічна адреса сайту (Google / Open Graph / sitemap) ---
# Локально: у репозиторії є .env.development → http://localhost:3000 для `npm run dev`.
# Продакшен: повний URL без слеша в кінці. Створіть .env.production.local (не комітиться):
#   NEXT_PUBLIC_SITE_URL="https://your-domain.com"
# Або задайте ту саму змінну в змінних середовища на Vercel / VPS / Docker.
# Код підтвердження з Google Search Console (HTML-тег) — опційно:
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# У Search Console: додайте властивість → підтвердіть домен → «Карта сайту» → https://your-domain.com/sitemap.xml

# --- Google Play (після публікації в консолі розробника) ---
# Повне HTTPS-посилання на картку застосунку (кнопка на головній, PWA manifest, JSON-LD, редирект /download/android).
# Має бути саме play.google.com/store/apps/details?id=… (перевірка: npm run check:play).
# NEXT_PUBLIC_PLAY_STORE_URL="https://play.google.com/store/apps/details?id=com.example.archi"
# Політика конфіденційності (HTTPS) — зазвичай потрібна в консолі Play і в застосунку:
# Канонічне посилання на політику (з префіксом локалі), напр. англійська версія:
# NEXT_PUBLIC_PRIVACY_POLICY_URL="https://your-domain.com/en/privacy"
# Умови користування (HTTPS), наприклад англійська версія:
# NEXT_PUBLIC_TERMS_OF_USE_URL="https://your-domain.com/en/terms"

# --- Android: або Play (вище), або прямий APK ---
# Якщо задано NEXT_PUBLIC_PLAY_STORE_URL — /download/android веде в Play; інакше — на APK.
# ANDROID_APK_DOWNLOAD_URL="https://expo.dev/artifacts/eas/....apk"

# --- Перевірка перед публікацією (сайт + Google Play + Search Console) ---
# Повний прогін і нагадування кроків: npm run prepare:publish
# Лише lint/build/test/readiness: npm run release:check
# Лише змінні середовища (з RUN_PLAY_CHECK=1 у CI): npm run play:readiness
# Детальний чекліст: scripts/PLAY_STORE_CHECKLIST.txt
#
# Android AAB (Expo WebView): каталог mobile/ — EXPO_PUBLIC_SITE_URL у mobile/.env.example
